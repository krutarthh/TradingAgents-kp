# Market data (optional; used as fallback after yfinance when listed in data_vendors)
ALPHA_VANTAGE_API_KEY=
# US macro series for forward/macro tools (recommended; official FRED observations batched per day)
FRED_API_KEY=
# SEC filing metadata + sections (recommended for fundamentals-quality primary documents)
API_NINJA_API_KEY=
# Earnings call transcripts (optional; primary provider for transcript tool — falls back to stub without key)
FMP_API_KEY=

# LangSmith — trace LLM + tool calls at https://smith.langchain.com (optional)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=TradingAgents
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=

# OpenAI-compatible clients (OpenAI, xAI, OpenRouter, NVIDIA, etc.): retry flaky HTTP 5xx / 429
# TRADINGAGENTS_LLM_TRANSIENT_RETRIES=8
# TRADINGAGENTS_LLM_TRANSIENT_BACKOFF_BASE=1.25
# TRADINGAGENTS_LLM_TRANSIENT_BACKOFF_CAP=45
# OPENAI_CLIENT_MAX_RETRIES=3
